<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description>Daily OP Report</Description>
  <Author>Mithren's Hospital</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DailyOPData">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString />
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DailyOPData">
      <Fields>
        <Field Name="id">
          <DataField>id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="patient_name">
          <DataField>patient_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="mobile_no">
          <DataField>mobile_no</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="op_fees">
          <DataField>op_fees</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="total_amount">
          <DataField>total_amount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DailyOPData</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <!-- HEADER SECTION -->
          <Textbox Name="HospitalPhone">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Ph: +91-95009 79113</Value>
                    <Style>
                      <Color>Navy</Color>
                      <FontSize>10pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Right</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.1in</Top>
            <Left>3.5in</Left>
            <Height>0.2in</Height>
            <Width>3in</Width>
          </Textbox>

          <Textbox Name="HospitalNameBox">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>MITHREN'S HOSPITAL</Value>
                    <Style>
                      <Color>Navy</Color>
                      <FontFamily>Arial</FontFamily>
                      <FontSize>22pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.3in</Top>
            <Left>1.5in</Left>
            <Height>0.5in</Height>
            <Width>5in</Width>
            <Style>
              <Border>
                <Color>Navy</Color>
                <Style>Solid</Style>
                <Width>1.5pt</Width>
              </Border>
              <VerticalAlign>Middle</VerticalAlign>
            </Style>
          </Textbox>

          <Textbox Name="Address">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>ERODE - 637408.</Value>
                    <Style>
                      <Color>Navy</Color>
                      <FontSize>10pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.85in</Top>
            <Left>1.5in</Left>
            <Height>0.2in</Height>
            <Width>5in</Width>
          </Textbox>

          <Textbox Name="DoctorDetails">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Dr. Mithren, M.B.B.S., M.S., FMAS, FIAGES, FALS.,
Consultant General &amp; Laparoscopic Surgeon</Value>
                    <Style>
                      <Color>Navy</Color>
                      <FontSize>10pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>1.1in</Top>
            <Left>0.5in</Left>
            <Height>0.4in</Height>
            <Width>7in</Width>
          </Textbox>

          <Line Name="HeaderLine">
            <Top>1.6in</Top>
            <Left>0in</Left>
            <Height>0in</Height>
            <Width>8in</Width>
            <Style>
              <Border>
                <Color>Navy</Color>
                <Style>Solid</Style>
                <Width>2pt</Width>
              </Border>
            </Style>
          </Line>

          <!-- REPORT TITLE -->
          <Textbox Name="ReportTitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>OP REPORT</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Color>Black</Color>
                      <FontSize>12pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>1.7in</Top>
            <Left>0in</Left>
            <Height>0.25in</Height>
            <Width>8in</Width>
          </Textbox>

          <!-- DATA TABLE -->
          <Tablix Name="Tablix1">
            <TablixBody>
              <TablixColumns>
                <TablixColumn>
                  <Width>1in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>3in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>2in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.5in</Width>
                </TablixColumn>
              </TablixColumns>
              <TablixRows>
                <!-- HEADER ROW -->
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderID">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>ID</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Maroon</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderName">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Patient Name</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Maroon</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderMobile">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Mobile No</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Maroon</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Center</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderOPFee">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>OP Fee</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Maroon</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
                <!-- DATA ROW -->
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="id">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Fields!id.Value</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="patient_name">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Fields!patient_name.Value</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                     <TablixCell>
                      <CellContents>
                        <Textbox Name="mobile_no">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Fields!mobile_no.Value</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Center</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="op_fees">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Fields!op_fees.Value</Value>
                                  <Style>
                                    <Format>N2</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                             <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember />
                <TablixMember />
                <TablixMember />
                <TablixMember />
              </TablixMembers>
            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember>
                  <KeepWithGroup>After</KeepWithGroup>
                </TablixMember>
                <TablixMember>
                  <Group Name="Details" />
                </TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>DailyOPData</DataSetName>
            <Top>2.2in</Top>
            <Left>0.25in</Left>
            <Height>0.6in</Height>
            <Width>7.5in</Width>
            <Style />
          </Tablix>

          <!-- SUMMARY SECTION -->
          <Textbox Name="LabelOPFee">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>OP FEE</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Color>Navy</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Right</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>3.5in</Top>
            <Left>4in</Left>
            <Height>0.25in</Height>
            <Width>2in</Width>
          </Textbox>

          <Textbox Name="ValOPFee">
             <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Sum(Fields!op_fees.Value, "DailyOPData")</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Format>N2</Format>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                   <TextAlign>Right</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>3.5in</Top>
            <Left>6.25in</Left>
            <Height>0.25in</Height>
            <Width>1.5in</Width>
          </Textbox>

          <Textbox Name="LabelTotalFee">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>TOTAL FEE</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Color>Navy</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Right</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>3.8in</Top>
            <Left>4in</Left>
            <Height>0.25in</Height>
            <Width>2in</Width>
          </Textbox>

           <Textbox Name="ValTotalFee">
             <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Sum(Fields!total_amount.Value, "DailyOPData")</Value>
                    <Style>
                      <FontWeight>Bold</FontWeight>
                      <Format>N2</Format>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                   <TextAlign>Right</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>3.8in</Top>
            <Left>6.25in</Left>
            <Height>0.25in</Height>
            <Width>1.5in</Width>
          </Textbox>

        </ReportItems>
        <Height>6in</Height>
        <Style />
      </Body>
      <Width>8.27in</Width> <!-- A4 Width -->
      <Page>
        <PageHeight>11.69in</PageHeight>
        <PageWidth>8.27in</PageWidth>
        <LeftMargin>0.1in</LeftMargin>
        <RightMargin>0.1in</RightMargin>
        <TopMargin>0.1in</TopMargin>
        <BottomMargin>0.1in</BottomMargin>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
</Report>
